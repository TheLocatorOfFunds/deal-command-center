{
  "expo": {
    "name": "DCC",
    "slug": "dcc-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dcc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fundlocators.dcc",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DCC uses the microphone for in-app Twilio voice calls with homeowners and contacts.",
        "NSUserNotificationsUsageDescription": "DCC sends you push notifications when new SMS, calls, or team chat messages arrive."
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.fundlocators.dcc"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#d97706",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "fundlocators",
    "extra": {
      "eas": {
        "projectId": "REPLACE_AFTER_EAS_INIT"
      }
    }
  }
}
